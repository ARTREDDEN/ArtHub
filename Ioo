local Players = game:GetService("Players")
local LP = Players.LocalPlayer
local camera = game.Workspace.CurrentCamera
local UIS = game:GetService("UserInputService")
local RunService = game:GetService("RunService")

--// Logo Setup
local LOGO_ID = "rbxassetid://81609873060038"

--// System Settings
local Settings = {
    Aimbot = false,
    Camlock = false,
    WallHack = false, 
    InfJump = false,  
    Noclip = false, 
    WallCheck = true,
    TeamCheck = true,
    MonsterLock = false,
    Smoothness = 0.2,
    LockPart = "Head",
    CurrentTarget = nil 
}

--// Noclip System
RunService.Stepped:Connect(function()
    if Settings.Noclip and LP.Character then
        for _, v in pairs(LP.Character:GetDescendants()) do
            if v:IsA("BasePart") then
                v.CanCollide = false
            end
        end
    end
end)

--// FOV Circle
local aimRadius = 150
local fovCircle = Drawing.new("Circle")
fovCircle.Visible = false
fovCircle.Color = Color3.new(1, 0, 0)
fovCircle.Thickness = 2
fovCircle.Radius = aimRadius
fovCircle.Filled = false

--// Visibility Check (Wall Check)
local function IsVisible(targetPart)
    local char = LP.Character
    if not char then return false end
    local rayParams = RaycastParams.new()
    rayParams.FilterType = Enum.RaycastFilterType.Blacklist
    rayParams.FilterDescendantsInstances = {char, camera}
    local rayResult = game.Workspace:Raycast(camera.CFrame.Position, (targetPart.Position - camera.CFrame.Position).Unit * 1000, rayParams)
    return rayResult == nil or rayResult.Instance:IsDescendantOf(targetPart.Parent)
end

--// WallHack (Highlight)
local function UpdateESP()
    for _, v in pairs(Players:GetPlayers()) do
        if v.Character then
            local hl = v.Character:FindFirstChild("Highlight") or Instance.new("Highlight", v.Character)
            hl.Enabled = Settings.WallHack
            hl.FillColor = Color3.fromRGB(255, 0, 0)
        end
    end
end

--// Infinite Jump
UIS.JumpRequest:Connect(function()
    if Settings.InfJump then
        LP.Character:FindFirstChildOfClass("Humanoid"):ChangeState("Jumping")
    end
end)

--// Target Finding Logic
local function GetTarget()
    if Settings.CurrentTarget and Settings.CurrentTarget:FindFirstChild("Humanoid") and Settings.CurrentTarget.Humanoid.Health > 0 then
        if Settings.WallCheck and IsVisible(Settings.CurrentTarget[Settings.LockPart]) then
            return Settings.CurrentTarget
        elseif not Settings.WallCheck then
            return Settings.CurrentTarget
        end
    end
    
    Settings.CurrentTarget = nil
    local target = nil
    local dist = math.huge
    local mouse = LP:GetMouse()
    
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LP and v.Character and v.Character:FindFirstChild(Settings.LockPart) then
            if Settings.TeamCheck and v.Team == LP.Team then continue end
            local hum = v.Character:FindFirstChild("Humanoid")
            if hum and hum.Health > 0 then
                local part = v.Character[Settings.LockPart]
                local pos, onScreen = camera:WorldToViewportPoint(part.Position)
                local visible = Settings.WallCheck and IsVisible(part) or not Settings.WallCheck
                
                if onScreen and visible then
                    local mDist = (Vector2.new(pos.X, pos.Y) - Vector2.new(mouse.X, mouse.Y)).Magnitude
                    if mDist < dist and mDist < aimRadius then
                        dist = mDist
                        target = v.Character
                    end
                end
            end
        end
    end
    Settings.CurrentTarget = target
    return target
end

--// Main Loop
RunService.RenderStepped:Connect(function()
    fovCircle.Position = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)
    
    if Settings.Aimbot then
        local t = GetTarget()
        if t then
            camera.CFrame = camera.CFrame:Lerp(CFrame.new(camera.CFrame.Position, t[Settings.LockPart].Position), Settings.Smoothness)
        end
    end
    
    if Settings.Camlock then
        local t = GetTarget()
        if t then
            camera.CFrame = CFrame.new(camera.CFrame.Position, t[Settings.LockPart].Position)
        end
    end
end)

